# ============================================================
# Aureon Group · variáveis de ambiente
# ============================================================
# Apenas estas três variáveis precisam ser configuradas.
# A Railway provisiona DATABASE_URL automaticamente quando
# você adiciona o plugin Postgres ao serviço.

# Postgres connection string (Railway preenche automaticamente
# quando você anexar o serviço Postgres ao projeto).
DATABASE_URL="postgresql://user:password@host:5432/aureon"

# Senha do painel admin acessível em /admin (mín. 6 caracteres).
ADMIN_PASSWORD="troque-esta-senha"

# Senha da área do corretor (/corretor). Pode ser compartilhada com o time
# de vendas. Mín. 6 caracteres.
CORRETOR_PASSWORD="troque-esta-senha-corretor"

# Segredo usado para assinar os cookies de sessão (admin e corretor).
# Gere com: openssl rand -hex 32  (mín. 32 caracteres)
SESSION_SECRET="troque-este-segredo-com-32-ou-mais-caracteres"

# Opcional. URL pública do site (usada em metadados / OG).
# NEXT_PUBLIC_SITE_URL="https://aureongroup.com.br"
